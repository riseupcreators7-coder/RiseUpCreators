# ===== Environment =====
NODE_ENV=development

# ===== Cloudinary =====
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ===== Email (Gmail app password) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=your_email@gmail.com

# ===== Auth / Cookies =====
SESSION_SECRET=replace-with-a-long-random-string-for-jwt-tokens
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=token

# ===== Database =====
# Local MongoDB (default port 27017)
MONGODB_URI=mongodb://localhost:27017/riseupcreator

# Cloud MongoDB Atlas (uncomment to use)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/riseupcreator?retryWrites=true&w=majority

# ===== Google AdSense Integration =====
VITE_GOOGLE_ADSENSE_PUBLISHER_ID=
VITE_GOOGLE_ADSENSE_INFEED_SLOT=
VITE_GOOGLE_ADSENSE_MOBILE_BANNER_SLOT=
VITE_GOOGLE_ADSENSE_DISPLAY_SLOT=

# ===== Audio Ad Configuration =====
VITE_AUDIO_AD_ENABLED=true
VITE_AUDIO_AD_FREQUENCY=5
SHIPROCKET_CHANNEL_ID=

# ===== NFT Marketplace & Blockchain Configuration =====
NFT_API_BASE_URL=https://riseup-api.himotechglobal.com
BLOCKCHAIN_API_URL=https://riseup-api.himotechglobal.com

# IPFS Configuration (Pinata)
IPFS_API_KEY=your_pinata_api_key
IPFS_API_SECRET=your_pinata_api_secret
# PINATA_JWT=your_jwt_token_here (optional)

# ===== YouTube API =====
YOUTUBE_API_KEY=your_youtube_api_key

# ===== Meta Platform API - Facebook App =====
META_APP_ID=your_facebook_app_id
META_APP_SECRET=your_facebook_app_secret
META_REDIRECT_URI=https://yourdomain.com/api/auth/meta/callback

# ===== Meta Platform API - Instagram App =====
META_INSTAGRAM_APP_ID=your_instagram_app_id
META_INSTAGRAM_APP_SECRET=your_instagram_app_secret
META_INSTAGRAM_REDIRECT_URI=https://yourdomain.com/api/auth/meta/callback

# ===== Razorpay Payment Gateway =====
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# ===== Smart Contract Addresses =====
MARKETPLACE_ADDRESS=0x4C4a2f8c81640e47606d3fd77B353E87Ba015584
FACTORY_ADDRESS=0x21dF544947ba3E8b3c32561399E88B52Dc8b2823
